generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(cuid())
  name               String
  email              String           @unique
  passwordHash       String
  roles              Role[]           @default([DESENVOLVEDOR])
  avatarUrl          String?
  mustChangePassword Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  assignments        TaskAssignment[] @relation("TaskAssignees")
}

model TaskAssignment {
  id           String   @id @default(cuid())
  taskId       String   @unique // ID do Taskrow (ex: TR-216967)
  title        String
  client       String
  users        User[]   @relation("TaskAssignees")
  status       String   @default("ASSIGNED")
  column       String   @default("todo") // todo, inProgress, inReview, done
  estimationHr String?
  trackedTime  String?  @default("0h")
  qaApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model GlobalSettings {
  id                 String   @id @default("global")
  hiddenSidebarItems String[] @default([]) // Guarda as rotas ocultas
  updatedAt          DateTime @updatedAt
}

enum Role {
  GESTOR
  ADMINISTRADOR
  DESENVOLVEDOR
}
